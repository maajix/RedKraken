{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://web-pentest-harness.example.test/schemas/coverage-v1.schema.json",
  "title": "Pentest coverage entry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "dimension", "key", "status", "reason", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^C-[a-f0-9]{16}$"},
    "dimension": {"enum": ["endpoint", "workflow", "family", "scenario"]},
    "key": {"type": "string", "minLength": 1},
    "status": {"enum": ["tested", "exhausted", "blocked", "not-applicable", "not-tested"]},
    "reason": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"enum": ["blocked", "not-tested"]}},
        "required": ["status"]
      },
      "then": {"properties": {"reason": {"minLength": 1, "pattern": "\\S"}}}
    },
    {
      "if": {"properties": {"dimension": {"const": "scenario"}}, "required": ["dimension"]},
      "then": {
        "properties": {
          "key": {
            "oneOf": [
              {"pattern": "^WSTG-v42-[A-Z]{4}-[0-9]{2}$"},
              {"pattern": "^v5\\.0\\.0-[0-9]+\\.[0-9]+\\.[0-9]+$"}
            ]
          }
        }
      }
    }
  ]
}
